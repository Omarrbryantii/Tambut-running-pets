{
  "manifest_version": 3,
  "name": "Tambut Running Pets",
  "version": "1.0.0",
  "description": "A fun desktop pet goose that roams your screen",
  "action": {
    "default_popup": "index.html",
    "default_title": "Tambut Pet"
  },
  "permissions": [],
  "icons": {},
  "web_accessible_resources": [
    {
      "resources": ["config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
